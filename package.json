{
  "name": "@safrochain/token-registry",
  "version": "0.1.0",
  "description": "Canonical chain, token, NFT and IBC registry for the Safrochain ecosystem (Safrimba, Safrochain Hub, Audoswap).",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "main": "dist/registry.json",
  "files": [
    "schemas",
    "templates",
    "mainnet",
    "testnet",
    "_IBC",
    "dist"
  ],
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "lint": "tsx scripts/lint.ts",
    "build": "tsx scripts/build-index.ts",
    "rewrite-image-urls": "tsx scripts/rewrite-image-urls.ts",
    "check": "pnpm validate && pnpm lint && pnpm build"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
