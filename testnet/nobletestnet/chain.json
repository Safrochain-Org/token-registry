{
  "$schema": "../../schemas/chain.schema.json",
  "chain_name": "nobletestnet",
  "chain_id": "grand-1",
  "pretty_name": "Noble Testnet",
  "chain_type": "cosmos",
  "status": "live",
  "network_type": "testnet",
  "website": "https://nobleassets.xyz",
  "bech32_prefix": "noble",
  "daemon_name": "nobled",
  "node_home": "$HOME/.noble",
  "slip44": 118,
  "fees": {
    "fee_tokens": [
      {
        "denom": "uusdc",
        "fixed_min_gas_price": 0,
        "low_gas_price": 0.01,
        "average_gas_price": 0.025,
        "high_gas_price": 0.04
      }
    ]
  },
  "staking": {
    "staking_tokens": [
      {
        "denom": "ustake"
      }
    ]
  },
  "codebase": {
    "cosmos_sdk_version": "0.50",
    "consensus": {
      "type": "cometbft",
      "version": "0.38"
    },
    "ibc_enabled": true
  },
  "apis": {
    "rpc": [
      {
        "address": "https://rpc.testnet.noble.strange.love",
        "provider": "Strangelove"
      }
    ],
    "rest": [
      {
        "address": "https://api.testnet.noble.strange.love",
        "provider": "Strangelove"
      }
    ]
  },
  "explorers": [
    {
      "kind": "mintscan",
      "url": "https://www.mintscan.io/noble-testnet",
      "tx_page": "https://www.mintscan.io/noble-testnet/transactions/${txHash}"
    }
  ],
  "features": [
    "stargate",
    "ibc-transfer",
    "ibc-go"
  ],
  "logo_URIs": {
    "png": "https://raw.githubusercontent.com/safrochain/token-registry/main/testnet/nobletestnet/images/noble.png"
  }
}
